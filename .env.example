# Clarity Hub App - Environment Variables Template
# Copy this file to .env.local and fill in your actual values
# NEVER commit .env.local or any file with real credentials to version control

# =============================================================================
# CLIENT-SIDE VARIABLES (VITE_ prefix = bundled into the browser app)
# =============================================================================
# Get these values from your Supabase project dashboard at https://app.supabase.com
# Go to: Project Settings > API

# Your Supabase project URL (public, safe for client-side)
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Your Supabase anon/public key (safe for client-side use, protected by RLS)
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# =============================================================================
# SERVER-SIDE VARIABLES (NO VITE_ prefix = only available in Vercel serverless functions)
# These are secrets and must NEVER be prefixed with VITE_
# Used by: api/ai-chat.ts, api/ai-embeddings.ts, api/process-file.ts
# =============================================================================

# Google Gemini API Key (primary multimodal model - used by /api/ai-chat)
# Get from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI API Key (deep legal reasoning + embeddings - used by /api/ai-chat, /api/ai-embeddings)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Supabase server-side config (used by api/ serverless functions for auth verification)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
