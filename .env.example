# Clarity Hub App - Environment Variables Template
# Copy this file to .env.local and fill in your actual values
# NEVER commit .env.local or any file with real credentials to version control

# =============================================================================
# CLIENT-SIDE VARIABLES (VITE_ prefix = bundled into the browser app)
# =============================================================================
# Get these values from your Supabase project dashboard at https://app.supabase.com
# Go to: Project Settings > API

# Your Supabase project URL (public, safe for client-side)
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Your Supabase anon/public key (safe for client-side use, protected by RLS)
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# =============================================================================
# SERVER-SIDE VARIABLES (NO VITE_ prefix = only available in Vercel serverless functions)
# These are secrets and must NEVER be prefixed with VITE_
# =============================================================================

# --- Required: Supabase server-side config ---
# Used by ALL API routes for JWT verification and database access:
#   /api/ai-chat, /api/ai-embeddings, /api/process-file,
#   /api/classify-file, /api/extract-timeline
# Get from: Supabase Dashboard > Project Settings > API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# --- Required: OpenAI API Key ---
# Used for: deep legal reasoning (/api/ai-chat), embeddings (/api/ai-embeddings),
#   document processing (/api/process-file), document classification (/api/classify-file),
#   timeline extraction (/api/extract-timeline)
# Models used: gpt-5.2 (chat), gpt-4.1-mini (processing/classification/timeline),
#   text-embedding-3-small (embeddings)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# --- Optional: Google Gemini API Key ---
# Used for: multimodal chat and follow-up generation (/api/ai-chat only)
# If not set, all AI chat queries will fall back to OpenAI GPT
# Get from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
